# =============================================================================
# GENESIS — Environment Configuration Template
# =============================================================================
# Copy this file to .env.development, .env.test, or .env.production
# and fill in the values for your environment.
#
# Priority (highest wins):
#   1. Actual OS environment variables
#   2. .env.{GENESIS_ENVIRONMENT} file (e.g. .env.development)
#   3. .env file (shared defaults)
#   4. Class-level defaults in webapi/settings.py
# =============================================================================

# --- Core Configuration ---
GENESIS_SERVICE_NAME=genesis
GENESIS_ENVIRONMENT=development
GENESIS_DEBUG=true
GENESIS_LOG_LEVEL=INFO

# --- OpenTelemetry ---
# Options: console, otlp, none
GENESIS_OTEL_EXPORTER=console
# Required when exporter=otlp:
# GENESIS_OTEL_ENDPOINT=http://localhost:4317
